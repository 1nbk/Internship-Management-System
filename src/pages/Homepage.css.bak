.bg-decoration {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    pointer-events: none;
    opacity: 0.4;
}

.blob-1 {
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.08) 0%, rgba(79, 70, 229, 0) 70%);
    top: -20vw;
    left: -10vw;
    animation: float 20s infinite alternate;
}

.blob-2 {
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0) 70%);
    bottom: -10vw;
    right: -5vw;
    animation: float 25s infinite alternate-reverse;
}

.blob-3 {
    width: 30vw;
    height: 30vw;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.03) 0%, rgba(245, 158, 11, 0) 70%);
    top: 40%;
    left: 30%;
    animation: float 30s infinite linear;
}

@keyframes float {
    0% {
        transform: translate(0, 0);
    }

    100% {
        transform: translate(40px, 40px);
    }
}

.homepage {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
}

/* Navbar */
.navbar {
    height: 70px;
    display: flex;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
}

.navbar .container {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--primary);
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
}

.nav-link {
    font-weight: 500;
    color: var(--text-muted);
    transition: var(--transition);
}

.nav-link:hover {
    color: var(--primary);
}

/* Hero */
.hero {
    padding: 100px 0;
    text-align: center;
    background: radial-gradient(circle at 50% 50%, #eff6ff 0%, #ffffff 100%);
}

.hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--text-main);
    max-width: 800px;
    margin: 0 auto 1.5rem;
    line-height: 1.1;
}

.hero-title span {
    color: var(--primary);
    position: relative;
}

.hero-title span::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: var(--primary-light);
    z-index: -1;
}

.hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2.5rem;
}

.hero-actions {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
}

/* Roles Grid */
.roles-section {
    padding: 80px 0;
    background-color: white;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-header h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
}

.section-header p {
    color: var(--text-muted);
    font-size: 1.125rem;
}

.roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.role-card {
    padding: 2.5rem;
    background-color: white;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
}

.role-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-premium);
    border-color: var(--primary-light);
}

.role-icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
}

.role-icon-wrapper.student {
    background-color: #eff6ff;
    color: #3b82f6;
}

.role-icon-wrapper.supervisor {
    background-color: #ecfdf5;
    color: #10b981;
}

.role-icon-wrapper.admin {
    background-color: #fff7ed;
    color: #f59e0b;
}

.role-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.role-card p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    flex-grow: 1;
}

.role-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.role-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--text-muted);
}

.role-features li svg {
    color: var(--success);
}

/* Footer */
.footer {
    margin-top: auto;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-muted);
    background-color: var(--bg-main);
}

@media (max-width: 768px) {
    .hero-title {
        font-size: 2.5rem;
    }

    .hero-actions {
        flex-direction: column;
        padding: 0 2rem;
    }
}